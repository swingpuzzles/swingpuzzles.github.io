{
  "compilerOptions": {
    "lib": ["esnext", "dom"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES6",
    "module": "ESNext",
    "rootDir": "src",
    "outDir": "dist",
    "paths": {
      "@babylonjs/*": ["./node_modules/@babylonjs/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
